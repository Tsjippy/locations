{
  "name": "locations",
  "version": "1.0.0",
  "description": "locations",
  "main": "./admin.js",
  "scripts": {
    "build": "webpack --entry ./admin.js --output-path . --output-filename locations_admin.min.js --progress --mode=production --devtool source-map",
    "user-location": "webpack --entry ./user_location.js --output-path . --output-filename user_location.min.js --progress --mode=production",
    "location": "webpack --config location.config.js",
    "all": "run-p build location user-location"
  },
